# ==============================
# ML Pipeline — Data & Models
# ==============================

# Raw data files (sensitive university data — never push)
server/ml_pipeline/data/*.xlsx
server/ml_pipeline/data/*.csv
server/ml_pipeline/data/*.json

# Keep templates (blank upload templates are safe to share)
!server/ml_pipeline/data/templates/

# Trained model artifacts (too large + reproducible from training scripts)
server/ml_pipeline/trained/*.pkl
server/ml_pipeline/trained/*.pt
server/ml_pipeline/trained/*.gpickle
server/ml_pipeline/trained/*.json
server/ml_pipeline/trained/*.png

